# ──────────────────────────────────────────────────────────────────────────────
# Pet Market Operations — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in production-grade values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ���─────────────────────────────���───────────────────────────────────────────────

# ── Security-critical secrets (REQUIRED — no defaults in production) ─────────

# JWT signing secret — at least 32 random characters.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# AES-256 field-encryption key — at least 32 random characters.
# Generate with: openssl rand -base64 48
FIELD_ENCRYPTION_KEY=

# PostgreSQL password — must match POSTGRES_PASSWORD on the postgres service.
# Generate with: openssl rand -base64 24
DB_PASSWORD=

# ── Optional overrides (safe defaults exist) ─────────────────────────────────

# NODE_ENV=production
# BCRYPT_ROUNDS=12
# FRONTEND_ORIGIN=https://your-domain.com
