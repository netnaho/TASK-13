{
  "name": "petmarket-unit-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/bcrypt": "^5.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "bcrypt": "^5.1.1"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@nestjs/common$": "<rootDir>/mocks/nestjs.ts",
      "^@nestjs/(.*)$": "<rootDir>/mocks/nestjs.ts",
      "^typeorm$": "<rootDir>/mocks/typeorm.ts"
    }
  }
}
