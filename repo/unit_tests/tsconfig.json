{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "strict": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "../backend/src/*": ["../backend/src/*"],
      "@nestjs/common": ["./mocks/nestjs.ts"],
      "@nestjs/*": ["./mocks/nestjs.ts"],
      "typeorm": ["./mocks/typeorm.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
